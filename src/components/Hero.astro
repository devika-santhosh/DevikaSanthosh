---
import profile from '../data/profile.json';
---

<section
  id="home"
  class="relative flex min-h-screen items-center justify-center overflow-hidden bg-bg"
>
  <!-- Animated dot grid background -->
  <div class="dot-grid absolute inset-0 opacity-20" aria-hidden="true"></div>

  <!-- Radial gradient overlay for depth -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,229,255,0.06)_0%,transparent_70%)]"
    aria-hidden="true"
  ></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
    <!-- Terminal typing line -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-lg border border-border bg-surface/60 px-5 py-3 font-heading text-sm backdrop-blur-sm sm:text-base">
      <span class="text-green">&gt;</span>
      <span id="typed-text" class="text-text"></span>
      <span class="cursor"></span>
    </div>

    <!-- Title -->
    <h2 class="fade-in mb-4 text-lg text-primary sm:text-xl md:text-2xl font-heading">
      {profile.title}
    </h2>

    <!-- Tagline -->
    <p class="fade-in mx-auto mb-10 max-w-2xl text-base text-muted sm:text-lg md:text-xl leading-relaxed">
      {profile.tagline}
    </p>

    <!-- CTA Buttons -->
    <div class="fade-in mb-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a href="#projects" class="btn-primary">
        View My Work
      </a>
      <a href="#contact" class="btn-outline">
        Get In Touch
      </a>
    </div>

    <!-- Social Icons -->
    <div class="fade-in flex items-center justify-center gap-6">
      <!-- LinkedIn -->
      <a
        href={profile.linkedin || '#'}
        target="_blank"
        rel="noopener noreferrer"
        class="group text-muted transition-colors duration-200 hover:text-primary"
        aria-label="LinkedIn"
      >
        <svg
          class="h-6 w-6 transition-transform duration-200 group-hover:scale-110"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- GitHub -->
      <a
        href={profile.github || '#'}
        target="_blank"
        rel="noopener noreferrer"
        class="group text-muted transition-colors duration-200 hover:text-primary"
        aria-label="GitHub"
      >
        <svg
          class="h-6 w-6 transition-transform duration-200 group-hover:scale-110"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
        </svg>
      </a>

      <!-- Email -->
      <a
        href={`mailto:${profile.email || ''}`}
        class="group text-muted transition-colors duration-200 hover:text-primary"
        aria-label="Email"
      >
        <svg
          class="h-6 w-6 transition-transform duration-200 group-hover:scale-110"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 4L12 13 2 4" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .dot-grid {
    background-image: radial-gradient(circle, rgba(0, 229, 255, 0.3) 1px, transparent 1px);
    background-size: 32px 32px;
    animation: dotDrift 20s linear infinite;
  }

  @keyframes dotDrift {
    0% {
      background-position: 0 0;
    }
    100% {
      background-position: 32px 32px;
    }
  }
</style>

<script>
  function initTyping() {
    const typedEl = document.getElementById('typed-text');
    if (!typedEl) return;

    const text = "Hello, I'm Devika Santhosh";
    let index = 0;
    typedEl.textContent = '';

    const type = () => {
      if (index < text.length) {
        typedEl.textContent += text.charAt(index);
        index++;
        setTimeout(type, 60);
      }
    };

    setTimeout(type, 600);
  }

  initTyping();
  document.addEventListener('astro:after-swap', initTyping);
</script>
