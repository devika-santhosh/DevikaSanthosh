<!-- Floating Chat Button -->
<button
  id="chatbot-toggle"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full bg-primary flex items-center justify-center shadow-lg cursor-pointer"
  style="animation: pulse-glow 2s infinite;"
  aria-label="Open chat assistant"
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0a0a0f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="m3 21 1.9-7.1C3.7 12 3 10.1 3 8c0-4.4 3.6-8 8-8s8 3.6 8 8-3.6 8-8 8c-2.1 0-4-.7-5.6-1.8L3 21z" />
  </svg>
</button>

<!-- Chat Popup Panel -->
<div
  id="chatbot-popup"
  class="fixed bottom-24 right-6 w-80 max-h-96 bg-surface rounded-xl border border-border shadow-2xl z-50 hidden flex-col overflow-hidden"
>
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-3 bg-primary text-bg">
    <span class="font-heading text-sm font-semibold">Ask me anything!</span>
    <button id="chatbot-close" class="hover:opacity-70 transition-opacity" aria-label="Close chat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Body: Guided Options -->
  <div class="p-4 space-y-3 overflow-y-auto">
    <p class="text-muted text-xs mb-2">Quick navigation:</p>

    <button data-scroll="#skills" class="chatbot-option block w-full bg-surface-hover border border-border rounded-lg p-3 text-left text-sm text-text hover:border-primary transition-colors duration-200">
      What are your skills?
    </button>

    <button data-scroll="#projects" class="chatbot-option block w-full bg-surface-hover border border-border rounded-lg p-3 text-left text-sm text-text hover:border-primary transition-colors duration-200">
      Show me your projects
    </button>

    <button data-scroll="#experience" class="chatbot-option block w-full bg-surface-hover border border-border rounded-lg p-3 text-left text-sm text-text hover:border-primary transition-colors duration-200">
      Work experience
    </button>

    <button data-scroll="#contact" class="chatbot-option block w-full bg-surface-hover border border-border rounded-lg p-3 text-left text-sm text-text hover:border-primary transition-colors duration-200">
      How to contact you?
    </button>
  </div>
</div>

<script>
  function initChatbot() {
    const toggle = document.getElementById('chatbot-toggle') as HTMLButtonElement;
    const popup = document.getElementById('chatbot-popup') as HTMLElement;
    const closeBtn = document.getElementById('chatbot-close') as HTMLButtonElement;
    const options = document.querySelectorAll<HTMLButtonElement>('.chatbot-option');

    if (!toggle || !popup || !closeBtn) return;

    const openPopup = () => {
      popup.classList.remove('hidden');
      popup.classList.add('flex');
    };

    const closePopup = () => {
      popup.classList.add('hidden');
      popup.classList.remove('flex');
    };

    toggle.addEventListener('click', () => {
      if (popup.classList.contains('hidden')) {
        openPopup();
      } else {
        closePopup();
      }
    });

    closeBtn.addEventListener('click', closePopup);

    options.forEach((option) => {
      option.addEventListener('click', () => {
        const target = option.dataset.scroll;
        if (target) {
          const el = document.querySelector(target);
          if (el) {
            el.scrollIntoView({ behavior: 'smooth' });
          }
        }
        closePopup();
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
        closePopup();
      }
    });
  }

  initChatbot();
  document.addEventListener('astro:after-swap', initChatbot);
</script>
